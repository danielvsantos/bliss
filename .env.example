# ─────────────────────────────────────────────────────────────────────────────
# Bliss  — environment variables (single source of truth)
# Copy this file to .env and run ./scripts/setup.sh to generate secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# REQUIRED — PostgreSQL connection URL
# Docker default: postgresql://bliss:<POSTGRES_PASSWORD>@postgres:5432/bliss
DATABASE_URL=postgresql://bliss:changeme@localhost:5432/bliss

# REQUIRED — Postgres superuser password (used by docker-compose to create the DB)
POSTGRES_PASSWORD=changeme

# ── Redis ─────────────────────────────────────────────────────────────────────
# REQUIRED — Redis connection URL (include password if set)
REDIS_URL=redis://:changeme@localhost:6379

# REQUIRED — Redis password (used by docker-compose redis service)
REDIS_PASSWORD=changeme

# Set to "true" when Redis uses TLS but with a self-signed cert (Upstash: false)
REDIS_SKIP_TLS_CHECK=false

# ── Secrets ───────────────────────────────────────────────────────────────────
# REQUIRED — AES-256-GCM encryption key for PII fields (min 32 chars)
ENCRYPTION_SECRET=replace-with-output-of-scripts-setup-sh

# OPTIONAL — Set during key rotation; remove once migration is complete
ENCRYPTION_SECRET_PREVIOUS=

# REQUIRED — JWT signing secret (current)
JWT_SECRET_CURRENT=replace-with-output-of-scripts-setup-sh

# OPTIONAL — Set during JWT secret rotation
JWT_SECRET_PREVIOUS=

# REQUIRED — NextAuth secret (Next.js session signing)
NEXTAUTH_SECRET=replace-with-output-of-scripts-setup-sh

# REQUIRED — Shared secret between API and backend (must match in both services)
INTERNAL_API_KEY=replace-with-output-of-scripts-setup-sh

# ── API layer (Next.js) ───────────────────────────────────────────────────────
# REQUIRED — Full public URL of the Next.js API layer
NEXTAUTH_URL=http://localhost:3000

# REQUIRED — URL of the backend service (server-to-server, not public)
BACKEND_URL=http://localhost:3001

# OPTIONAL — Cookie domain for cross-subdomain auth (leave empty for localhost)
COOKIE_DOMAIN=

# ── Backend service (Express) ────────────────────────────────────────────────
# Port for the backend Express server
PORT=3001

# OPTIONAL — Comma-separated list of allowed CORS origins for the backend
ALLOWED_ORIGINS=http://localhost:3000

# ── Storage ───────────────────────────────────────────────────────────────────
# OPTIONAL — "local" (default) or "gcs"
STORAGE_BACKEND=local

# OPTIONAL — Local storage directory (used when STORAGE_BACKEND=local)
# MUST be an absolute path — the API and backend run from different working
# directories so a relative path resolves to different locations for each.
# Example: /home/youruser/bliss/data/uploads
LOCAL_STORAGE_DIR=/absolute/path/to/bliss/data/uploads

# OPTIONAL — GCS bucket name (required when STORAGE_BACKEND=gcs)
GCS_BUCKET_NAME=

# OPTIONAL — GCS service account JSON string (required when STORAGE_BACKEND=gcs)
GCS_SERVICE_ACCOUNT_JSON=

# ── Frontend ─────────────────────────────────────────────────────────────────
# REQUIRED — Public-facing URL of the API layer (baked into the web bundle at build time)
NEXT_PUBLIC_API_URL=http://localhost:3000

# REQUIRED — Public-facing URL of the frontend (used by the API for CORS)
FRONTEND_URL=http://localhost:8080

# ── Plaid (optional — CSV import works without Plaid) ────────────────────────
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_WEBHOOK_URL=
# Default Plaid history window (days) written to Tenant.plaidHistoryDays at signup
PLAID_HISTORY_DAYS=1

# ═════════════════════════════════════════════════════════════════════════════
# AI PROVIDER — REQUIRED for transaction classification and financial insights
# ─────────────────────────────────────────────────────────────────────────────
# Bliss depends on an LLM for two features it cannot work without:
#   1. Tier 4 transaction classification (when no exact or vector match exists)
#   2. Financial insights (monthly, quarterly, annual, portfolio)
#
# You MUST configure one provider. Supported: gemini | openai | anthropic.
# ═════════════════════════════════════════════════════════════════════════════
LLM_PROVIDER=gemini

# Embedding provider override. Only required when LLM_PROVIDER=anthropic,
# because Anthropic does not provide an embedding API. For gemini or openai,
# leave blank to let the embedding provider follow LLM_PROVIDER.
# Supported: gemini | openai.
EMBEDDING_PROVIDER=

# ── API keys — set the one matching LLM_PROVIDER (and EMBEDDING_PROVIDER
#     if you configured a separate embedding provider).
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Model overrides (optional — each adapter has sensible defaults)
# Defaults per provider:
#   gemini    : embedding=gemini-embedding-001, classification=gemini-3-flash-preview, insight=gemini-3.1-pro-preview
#   openai    : embedding=text-embedding-3-small, classification=gpt-4.1-mini,         insight=gpt-4.1
#   anthropic : embedding=<not supported>,       classification=claude-sonnet-4-6,     insight=claude-sonnet-4-6
EMBEDDING_MODEL=
CLASSIFICATION_MODEL=
INSIGHT_MODEL=

# ── Market Data (optional — disables stock price fetching if not set) ─────────
# Supported providers: TWELVE_DATA (recommended), FINNHUB
STOCK_PROVIDER=TWELVE_DATA
TWELVE_DATA_API_KEY=
FINNHUB_API_KEY=

# ── Currency Rates (optional — disables automatic FX rate fetching if not set) ─
# CurrencyLayer API key for historical exchange rates (used by portfolio & analytics)
CURRENCYLAYER_API_KEY=

# ── Observability (optional) ─────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
