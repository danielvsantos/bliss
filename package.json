{
  "name": "bliss",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:api": "pnpm --filter @bliss/api test",
    "test:backend": "pnpm --filter @bliss/backend test",
    "test:web": "pnpm --filter @bliss/web test",
    "postinstall": "prisma generate --schema=prisma/schema.prisma"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
