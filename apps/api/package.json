{
  "name": "@bliss/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "pnpm --filter @bliss/shared build && prisma generate --no-engine --schema=../../prisma/schema.prisma && next build",
    "start": "next start",
    "lint": "next lint",
    "knip": "knip",
    "chat-with-bliss": "node scripts/chat.mjs",
    "update-bliss": "node scripts/updateBliss.mjs",
    "test": "vitest run",
    "test:unit": "vitest run __tests__/unit",
    "test:integration": "vitest run __tests__/integration",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@bliss/shared": "workspace:*",
    "@bull-board/api": "^5.18.0",
    "@google-cloud/storage": "^7.19.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.70.1",
    "@opentelemetry/context-async-hooks": "^2.5.1",
    "@opentelemetry/core": "^2.5.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.212.0",
    "@opentelemetry/instrumentation": "^0.212.0",
    "@opentelemetry/sdk-node": "^0.212.0",
    "@opentelemetry/sdk-trace-base": "^2.5.1",
    "@opentelemetry/semantic-conventions": "^1.34.0",
    "@opentelemetry/winston-transport": "^0.22.0",
    "@prisma/client": "^6.6.0",
    "@prisma/extension-accelerate": "^1.3.0",
    "@sentry/nextjs": "^9.10.1",
    "axios": "^1.15.0",
    "bootstrap": "^5.3.3",
    "cli-progress": "^3.12.0",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "decimal.js": "^10.6.0",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "express-rate-limit": "^7.5.0",
    "form-data": "^4.0.2",
    "formidable": "^3.5.2",
    "http-status-codes": "^2.3.0",
    "ioredis": "^5.9.3",
    "jose": "^6.1.3",
    "jsonwebtoken": "^9.0.2",
    "next": "^15.5.15",
    "next-auth": "^4.24.11",
    "node-fetch": "^2.7.0",
    "papaparse": "^5.5.3",
    "plaid": "^41.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^13.0.0",
    "prisma": "^6.19.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.22.0",
    "eslint-config-next": "15.2.2",
    "knip": "^5.62.0",
    "msw": "^2.12.10",
    "vite": "^6.4.2",
    "vitest": "^4.0.18"
  },
  "prisma": {
    "generate": "npx prisma generate --no-engine"
  }
}
