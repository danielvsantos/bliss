{
  "name": "@bliss/backend",
  "version": "1.0.0",
  "description": "Bliss backend service with Express, Prisma, Redis, and BullMQ",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node src/index.js",
    "start:dev": "nodemon src/index.js",
    "test": "jest",
    "test:unit": "jest --testPathPatterns=unit",
    "test:integration": "jest --testPathPatterns=integration",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "knip": "knip",
    "prisma:generate": "prisma generate --schema=../../prisma/schema.prisma",
    "prisma:migrate": "prisma migrate deploy --schema=../../prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=../../prisma/schema.prisma"
  },
  "dependencies": {
    "@bliss/shared": "workspace:*",
    "@bull-board/api": "^7.0.0",
    "@google-cloud/storage": "^7.19.0",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^6.1.0",
    "@sentry/node": "^10.40.0",
    "axios": "^1.15.0",
    "bullmq": "^5.51.0",
    "cors": "^2.8.5",
    "decimal.js": "^10.4.3",
    "dotenv": "^16.4.0",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.2.1",
    "helmet": "^7.1.0",
    "http-status-codes": "^2.3.0",
    "ioredis": "^5.3.2",
    "p-limit": "^7.3.0",
    "papaparse": "^5.5.3",
    "plaid": "^41.0.0",
    "uuid": "^11.1.0",
    "winston": "^3.17.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "jest": "^30.2.0",
    "jest-mock-extended": "^4.0.0",
    "knip": "^5.62.0",
    "nodemon": "^3.0.3",
    "prisma": "^6.1.0",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
