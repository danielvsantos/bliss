# Hoist Prisma packages to root node_modules so that the generated client
# (output at node_modules/.prisma/client) can resolve them via Node's
# standard module resolution. Without this, pnpm's strict virtual store
# keeps them workspace-local and prisma generate tries to self-install.
public-hoist-pattern[]=prisma
public-hoist-pattern[]=@prisma
public-hoist-pattern[]=@prisma/*
